{
  "name": "react-native-brightness-manager",
  "version": "0.3.0",
  "description": "Native brightness manager for React Native (no Expo)",
  "homepage": "https://github.com/ajayrajtiwari/react-native-brightness-manager",
  "main": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "react-native.config.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-brightness-manager-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "brightness",
    "screen-brightness",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajayrajtiwari/react-native-brightness-manager.git"
  },
  "author": "Ajay Raj Tiwari <ajprince0607@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "react": "18",
    "react-native-builder-bob": "^0.40.17"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx|js)$": "babel-jest"
    },
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.js"
    },
    "testMatch": ["<rootDir>/src/__tests__/**/*.{ts,tsx}"]
  },
  "workspaces": [
    "example"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
